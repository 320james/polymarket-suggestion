# --- Database ---------------------------------------------------------------
# SQLite file lives in the repo-root ./data directory (bind-mounted in Docker).
# NOTE: Prisma resolves `file:` paths RELATIVE TO THE SCHEMA FILE
# (prisma/schema.prisma), so `../data/...` climbs out of prisma/ into ./data/.
DATABASE_URL=file:../data/app.db

# --- Worker / Web operational ----------------------------------------------
WEB_PORT=3000
POLL_INTERVAL_SEC=120
LOG_LEVEL=info

# --- Notifications (Telegram is the default channel) ------------------------
# See README/SETUP.md for how to create the bot and find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
